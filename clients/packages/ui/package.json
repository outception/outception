{
  "name": "@outception-com/ui",
  "version": "0.1.2",
  "description": "Outception UI Components — This is a private library for the Outception project. You probably shouldn't use it directly in your own projects.",
  "author": "Outception",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/outception/outception.git",
    "directory": "clients/packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "format": "oxfmt ./src",
    "format:check": "oxfmt --check ./src",
    "lint": "pnpm format:check && eslint --max-warnings 0 .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@outception-com/orbit": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "react-hook-form": "~7.72.1",
    "react-timeago": "^8.3.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@outception-com/eslint-config": "workspace:*",
    "@outception-com/typescript-config": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
