{
  "$schema": "https://v2-9-4.turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "OUTCEPTION_API_URL",
    "EXPO_PUBLIC_OUTCEPTION_SERVER_URL",
    "NODE_ENV",
    "NEXT_PHASE",
    "NEXT_RUNTIME",
    "NEXT_PUBLIC_ENVIRONMENT",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_FRONTEND_BASE_URL",
    "OUTCEPTION_PREVIEW_ACCESS_TOKEN",
    "OUTCEPTION_PREVIEW_BUILD",
    "OUTCEPTION_PREVIEW_BACKEND_HOST",
    "VERCEL_ENV",
    "VERCEL_GIT_PULL_REQUEST_ID",
    "VERCEL_URL",
    "NEXT_PUBLIC_VERCEL_ENV",
    "NEXT_PUBLIC_LOGIN_PATH",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_POSTHOG_TOKEN",
    "SENTRY_AUTH_TOKEN",
    "VERCEL_GIT_COMMIT_SHA",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_PROJECT",
    "SENTRY_ORG",
    "OUTCEPTION_AUTH_COOKIE_KEY",
    "S3_PUBLIC_IMAGES_BUCKET_PROTOCOL",
    "S3_PUBLIC_IMAGES_BUCKET_HOSTNAME",
    "S3_PUBLIC_IMAGES_BUCKET_PORT",
    "S3_PUBLIC_IMAGES_BUCKET_PATHNAME",
    "S3_UPLOAD_ORIGINS",
    "GRAM_API_KEY",
    "GRAM_API_URL",
    "CI"
  ],
  "tasks": {
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
