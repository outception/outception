{
  "theme": "maple",
  "styling": {
    "latex": false
  },
  "appearance": {
    "default": "system"
  },
  "name": "Outception",
  "description": "Outception API & developer docs — a live news wall with pay-to-promote.",
  "colors": {
    "primary": "#000",
    "light": "#fff",
    "dark": "#000"
  },
  "background": {
    "color": {
      "dark": "#131316"
    }
  },
  "favicon": "/logo.svg",
  "integrations": {
    "ga4": {
      "measurementId": ""
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "compass",
        "groups": [
          {
            "group": "Bootup",
            "pages": [
              "introduction"
            ]
          },
          {
            "group": "Integrate",
            "pages": [
              "integrate/authentication",
              {
                "group": "Webhooks",
                "pages": [
                  "integrate/webhooks/endpoints",
                  "integrate/webhooks/locally",
                  "integrate/webhooks/delivery"
                ]
              },
              {
                "group": "OAuth 2.0",
                "pages": [
                  "integrate/oauth2/introduction",
                  "integrate/oauth2/setup",
                  "integrate/oauth2/connect"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "rectangle-terminal",
        "groups": [
          {
            "group": "General",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Core API",
            "pages": [
              {
                "group": "News",
                "pages": [
                  "api-reference/news/sources",
                  "api-reference/news/get-source",
                  "api-reference/news/search",
                  "api-reference/news/batch"
                ]
              },
              {
                "group": "Promotions",
                "pages": [
                  "api-reference/promotions/get-featured",
                  "api-reference/promotions/get-pricing",
                  "api-reference/promotions/get-category",
                  "api-reference/promotions/click"
                ]
              },
              {
                "group": "Organizations",
                "pages": [
                  "api-reference/organizations/list",
                  "api-reference/organizations/get",
                  "api-reference/organizations/update"
                ]
              },
              {
                "group": "Organization Access Tokens",
                "pages": [
                  "api-reference/organization-access-tokens/list",
                  "api-reference/organization-access-tokens/create",
                  "api-reference/organization-access-tokens/update",
                  "api-reference/organization-access-tokens/delete"
                ]
              },
              {
                "group": "OAuth2",
                "pages": [
                  "api-reference/oauth2/authorize",
                  "api-reference/oauth2/token",
                  "api-reference/oauth2/userinfo",
                  "api-reference/oauth2/introspect",
                  "api-reference/oauth2/revoke",
                  "api-reference/oauth2/register",
                  "api-reference/oauth2/get-client",
                  "api-reference/oauth2/update-client",
                  "api-reference/oauth2/delete-client"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Support",
        "icon": "square-question",
        "pages": [
          "support",
          "security"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg",
    "href": "https://outception.com"
  },
  "navbar": {
    "links": [
      {
        "label": "llms-full.txt",
        "href": "https://outception.com/docs/llms-full.txt"
      },
      {
        "label": "Contact support",
        "href": "https://outception.com/docs/support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://outception.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/outceptionx",
      "github": "https://github.com/outception/outception",
      "discord": "https://discord.gg/jZVk5aeMV"
    }
  },
  "redirects": [
    {
      "source": "/api",
      "destination": "/api-reference"
    },
    {
      "source": "/api/:path*",
      "destination": "/api-reference"
    },
    {
      "source": "/docs/api",
      "destination": "/api-reference"
    },
    {
      "source": "/docs/api/:path*",
      "destination": "/api-reference"
    },
    {
      "source": "/developers/:path*",
      "destination": "/integrate/authentication"
    },
    {
      "source": "/docs/developers/:path*",
      "destination": "/integrate/authentication"
    },
    {
      "source": "/docs/support",
      "destination": "/support"
    },
    {
      "source": "/documentation/welcome-to-outception",
      "destination": "/introduction"
    },
    {
      "source": "/documentation/tools/outception-init",
      "destination": "/introduction#quickstart-from-cli"
    },
    {
      "source": "/documentation/basics/getting-started",
      "destination": "/introduction"
    },
    {
      "source": "/documentation/support",
      "destination": "/support"
    },
    {
      "source": "/documentation/integration-guides/webhooks",
      "destination": "/integrate/webhooks/endpoints"
    },
    {
      "source": "/documentation/integration-guides/authenticating-with-outception",
      "destination": "/integrate/authentication"
    },
    {
      "source": "/developers/webhooks",
      "destination": "/integrate/webhooks/endpoints"
    },
    {
      "source": "/docs/developers/webhooks",
      "destination": "/integrate/webhooks/endpoints"
    },
    {
      "source": "/onboarding",
      "destination": "/introduction#quickstart"
    },
    {
      "source": "/docs/onboarding",
      "destination": "/introduction#quickstart"
    }
  ]
}
