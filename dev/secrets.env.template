# Outception Development Secrets
# Copy to ~/.config/outception/secrets.env and fill in values
#
# This file is used to share secrets across multiple Git worktrees.
# Run ./dev/setup-environment to automatically merge these into server/.env

# GitHub OAuth - create app at https://github.com/settings/apps
# Or run: ./dev/setup-environment --setup-github-app
OUTCEPTION_GITHUB_CLIENT_ID=
OUTCEPTION_GITHUB_CLIENT_SECRET=
OUTCEPTION_GITHUB_APP_WEBHOOK_SECRET=
OUTCEPTION_GITHUB_APP_IDENTIFIER=
OUTCEPTION_GITHUB_APP_PRIVATE_KEY=
OUTCEPTION_GITHUB_APP_NAMESPACE=

# GitHub Repository Benefits App (usually same as above)
OUTCEPTION_GITHUB_REPOSITORY_BENEFITS_APP_NAMESPACE=
OUTCEPTION_GITHUB_REPOSITORY_BENEFITS_APP_IDENTIFIER=
OUTCEPTION_GITHUB_REPOSITORY_BENEFITS_APP_PRIVATE_KEY=
OUTCEPTION_GITHUB_REPOSITORY_BENEFITS_CLIENT_ID=
OUTCEPTION_GITHUB_REPOSITORY_BENEFITS_CLIENT_SECRET=

# Stripe - from https://dashboard.stripe.com/test/apikeys
OUTCEPTION_STRIPE_SECRET_KEY=
OUTCEPTION_STRIPE_PUBLISHABLE_KEY=
OUTCEPTION_STRIPE_WEBHOOK_SECRET=
OUTCEPTION_STRIPE_CONNECT_WEBHOOK_SECRET=
