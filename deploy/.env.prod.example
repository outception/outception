# =============================================================================
# Outception — production environment (Hetzner + Cloudflare + Cloudflare R2)
# Copy to `deploy/.env.prod` and fill in. NEVER commit the filled-in file.
#   cp deploy/.env.prod.example deploy/.env.prod
# Backend settings are prefixed OUTCEPTION_. See server/outception/config.py.
# =============================================================================

# --- Domains (used by Caddy + cookie/CORS settings below) --------------------
# The public site and the API hostname. Both must be DNS records on Cloudflare
# pointing at this server's IP (proxied / orange-cloud is fine).
WEB_DOMAIN=outception.com
API_DOMAIN=api.outception.com

# Cloudflare API token with Zone:DNS:Edit on the zone — used by Caddy for
# automatic TLS via the DNS-01 challenge (works behind the orange cloud).
CF_API_TOKEN=

# Container image tag to run (the deploy workflow sets this to the git SHA).
IMAGE_TAG=latest

# --- Core backend ------------------------------------------------------------
OUTCEPTION_ENV=production
OUTCEPTION_LOG_LEVEL=INFO
# Strong random secret — keys all token hashing. Generate: openssl rand -hex 32
# Startup REFUSES to boot in production if this is left at the dev default.
OUTCEPTION_SECRET=
# JWKS is a PATH to a JWKS file (not inline JSON). Generate a keypair and place
# it at deploy/secrets/jwks.json on the host; compose mounts it read-only at the
# path below. Generate with (from server/): uv run task generate_dev_jwks
# then move .jwks.json to deploy/secrets/jwks.json. CURRENT_JWK_KID must match a
# kid in that file (the generator uses "outception_dev").
OUTCEPTION_JWKS=/run/secrets/jwks.json
OUTCEPTION_CURRENT_JWK_KID=outception_dev
# Public URLs
OUTCEPTION_BASE_URL=https://api.outception.com
OUTCEPTION_FRONTEND_BASE_URL=https://outception.com

# --- Host / CORS / cookies (BREAKS auth if wrong — see DEPLOYMENT notes) -----
# Hosts the API will accept (host:port or host). Include the API + web domains.
OUTCEPTION_ALLOWED_HOSTS=["api.outception.com","outception.com"]
# Browser origins allowed to call the API with credentials.
OUTCEPTION_CORS_ORIGINS=["https://outception.com"]
# Cookie domain so sessions are valid across web + api subdomains.
# Leading dot scopes the cookie to the apex + all subdomains.
OUTCEPTION_AUTHENTICATION_SESSION_COOKIE_DOMAIN=.outception.com
OUTCEPTION_USER_SESSION_COOKIE_DOMAIN=.outception.com
OUTCEPTION_OAUTH2_SESSION_STATE_COOKIE_DOMAIN=.outception.com

# --- PostgreSQL (the `db` service in docker-compose.prod.yml) -----------------
OUTCEPTION_POSTGRES_USER=outception
OUTCEPTION_POSTGRES_PWD=
OUTCEPTION_POSTGRES_HOST=db
OUTCEPTION_POSTGRES_PORT=5432
OUTCEPTION_POSTGRES_DATABASE=outception
# Read-only user created by init-readonly-user.sql (optional; leave read-replica
# settings unset to route read queries to the primary).
OUTCEPTION_POSTGRES_READ_PWD=

# --- Redis (the `redis` service) ---------------------------------------------
OUTCEPTION_REDIS_HOST=redis
OUTCEPTION_REDIS_PORT=6379
OUTCEPTION_REDIS_DB=0

# --- Object storage: Cloudflare R2 (S3-compatible, no code change needed) -----
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
#OUTCEPTION_S3_ENDPOINT_URL=  # leave unset unless using R2
OUTCEPTION_AWS_ACCESS_KEY_ID=
OUTCEPTION_AWS_SECRET_ACCESS_KEY=
OUTCEPTION_AWS_REGION=auto
# Buckets (create in the Cloudflare R2 dashboard). Only needed if you enable
# the optional observability features; the news/promotion product stores no
# user files, so these can stay empty for a basic deploy.
# OUTCEPTION_S3_LOGS_BUCKET_NAME=
# OUTCEPTION_MEMORY_PROFILE_S3_BUCKET_NAME=

# --- Email (Resend) ----------------------------------------------------------
# Without this, the default sender just logs and no mail is delivered.
OUTCEPTION_EMAIL_SENDER=resend
OUTCEPTION_RESEND_API_KEY=
OUTCEPTION_EMAIL_FROM_NAME=Outception
OUTCEPTION_EMAIL_FROM_DOMAIN=notifications.outception.com
OUTCEPTION_EMAIL_FROM_LOCAL=mail

# --- Promotions: external payment gateway ------------------------------------
# Checkout stays disabled (create endpoint 503s) until these are set.
OUTCEPTION_PROMOTION_PRODUCT_ID=
OUTCEPTION_PAYMENT_GATEWAY_BASE_URL=https://api.polar.sh
OUTCEPTION_PAYMENT_GATEWAY_ACCESS_TOKEN=
OUTCEPTION_PAYMENT_GATEWAY_WEBHOOK_SECRET=

# --- OAuth providers (set the ones you use) ----------------------------------
OUTCEPTION_GOOGLE_CLIENT_ID=
OUTCEPTION_GOOGLE_CLIENT_SECRET=
OUTCEPTION_GITHUB_CLIENT_ID=
OUTCEPTION_GITHUB_CLIENT_SECRET=
# Apple (optional)
OUTCEPTION_APPLE_CLIENT_ID=
OUTCEPTION_APPLE_TEAM_ID=
OUTCEPTION_APPLE_KEY_ID=
OUTCEPTION_APPLE_KEY_VALUE=

# --- Optional: analytics / error tracking ------------------------------------
# OUTCEPTION_SENTRY_DSN=
# OUTCEPTION_TINYBIRD_API_URL=
# OUTCEPTION_TINYBIRD_API_TOKEN=

# --- Web build-time public vars (baked into the Next.js image) ---------------
# These are read at BUILD time by the web image, not runtime.
NEXT_PUBLIC_API_URL=https://api.outception.com
NEXT_PUBLIC_FRONTEND_BASE_URL=https://outception.com
NEXT_PUBLIC_ENVIRONMENT=production
# Server-side (Next middleware → backend) API URL, container-to-container:
OUTCEPTION_API_URL=http://api:10000
